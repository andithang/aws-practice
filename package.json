{
  "name": "aws-practice",
  "private": true,
  "scripts": {
    "build:functions": "echo 'Build handled by sam build with esbuild'",
    "validate": "sam validate",
    "build:frontend": "cd frontend && npm run build",
    "start:frontend": "cd frontend && npm run dev",
    "test": "vitest run",
    "lint": "eslint \"**/*.{ts,tsx,json,html}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.775.0",
    "@aws-sdk/client-ssm": "^3.775.0",
    "@aws-sdk/lib-dynamodb": "^3.775.0",
    "busboy": "^1.6.0",
    "csv-parse": "^6.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@html-eslint/eslint-plugin": "^0.47.0",
    "@html-eslint/parser": "^0.47.0",
    "@types/aws-lambda": "^8.10.137",
    "@types/node": "^25.5.2",
    "eslint": "^9.37.0",
    "eslint-plugin-jsonc": "^2.20.1",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.1",
    "lint-staged": "^16.2.6",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.46.1",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,json,html}": "eslint --fix --max-warnings=0"
  }
}
