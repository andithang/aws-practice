# GitHub Actions repository secrets for .github/workflows/deploy.yml
AWS_REGION=ap-southeast-1
AWS_ROLE_TO_ASSUME=arn:aws:iam::<account-id>:role/<github-oidc-role>
SAM_STACK_NAME=aws-exam-practice
ADMIN_API_KEY_NAME=aws-exam-admin-key
ADMIN_API_KEY_VALUE=replace-with-strong-admin-api-key
GEMINI_MODEL=gemini-2.5-flash
FRONTEND_BACKEND_API_BASE_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod
