# GitHub Actions repository secrets for .github/workflows/deploy.yml
AWS_REGION=ap-southeast-1
AWS_ROLE_TO_ASSUME=arn:aws:iam::<account-id>:role/<github-oidc-role>
SAM_STACK_NAME=aws-exam-practice
GEMINI_MODEL=gemini-2.5-flash
S3_ARTIFACTS_BUCKET=your-sam-artifacts-bucket-name
FRONTEND_BACKEND_API_BASE_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod

# Lambda runtime environment variables (from template.yaml)
# Globals.Function.Environment.Variables
TABLE_NAME=aws_exam_questions
GEMINI_API_KEY_PARAMETER_NAME=/andithang-practice/<stack-name>/gemini-api-key
CORS_ALLOW_ORIGIN=https://aws-practice.andithang.org

# Frontend build-time environment variable (GitHub Pages)
# (In GitHub Actions, this is populated from FRONTEND_BACKEND_API_BASE_URL.)
NEXT_PUBLIC_API_BASE_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod
NEXT_PUBLIC_COGNITO_REGION=<region>
NEXT_PUBLIC_COGNITO_USER_POOL_ID=<user-pool-id>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<app-client-id>

# Optional runtime override used by src/functions/common/generation.ts
# If empty, code reads apiKey from GEMINI_API_KEY_PARAMETER_NAME parameter value.
GEMINI_API_KEY=
